{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find source:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(cat source/*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git blame:*)",
      "Bash(git status)",
      "Bash(git -C source/*)",
      "Bash(ctags:*)",
      "Bash(cscope:*)",
      "Bash(ninja -C build*)",
      "Bash(meson*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(rm:*)",
      "Bash(mv:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(rm -rf /*)",
      "Bash(sudo:*)"
    ]
  }
}
